SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
LEDGERMEM_API_KEY=lm_your_api_key
LEDGERMEM_WORKSPACE_ID=ws_your_workspace
SOCKET_MODE=true
PORT=3000
# Comma-separated list of channel IDs allowed to capture (empty = all channels)
OPT_IN_CHANNELS=
# Or point to a JSON array file
OPT_IN_FILE=./channels.json
